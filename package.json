{
  "name": "@prepsavant/mcp",
  "version": "2.3.0",
  "description": "Local Sam MCP runner — pinned-test sandbox grading and MCP-sampling persona for the Sam interview-prep coach.",
  "license": "MIT",
  "bin": {
    "prepsavant": "dist/cli.js"
  },
  "type": "module",
  "main": "dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./sandbox/node": "./src/sandbox/node.ts",
    "./sandbox/python": "./src/sandbox/python.ts",
    "./sandbox/php": "./src/sandbox/php.ts",
    "./sandbox/csharp": "./src/sandbox/csharp.ts",
    "./sandbox/kotlin": "./src/sandbox/kotlin.ts",
    "./sandbox/cpp": "./src/sandbox/cpp.ts",
    "./sandbox/java": "./src/sandbox/java.ts",
    "./sandbox/go": "./src/sandbox/go.ts",
    "./sandbox/rust": "./src/sandbox/rust.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts",
    "doctor": "node dist/cli.js doctor"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@workspace/ai-assisted-events": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "@workspace/mcp-runner-version": "workspace:*",
    "@workspace/session-milestones": "workspace:*",
    "@workspace/sam-market-context-shared": "workspace:*",
    "esbuild": "^0.27.3",
    "tsx": "catalog:",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
